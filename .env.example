# Copy to .env and fill in. .env is git-ignored. Never commit real keys.

# Intervals.icu (Settings -> Developer)
INTERVALS_API_KEY=your_key_here
INTERVALS_ATHLETE_ID=i140486

# Garmin Connect (HRV, sleep, Body Battery). Token is cached after first login,
# so MFA is only needed once. Set GARMIN_MFA only for a non-interactive first run.
GARMIN_EMAIL=your_email_here
GARMIN_PASSWORD=your_password_here
# GARMIN_MFA=123456

# Athlete defaults (optional; pulled from Intervals.icu if blank)
ATHLETE_WEIGHT_KG=74
